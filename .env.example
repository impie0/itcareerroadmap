# PostgreSQL container credentials (used by docker-compose.yml's `db` service)
POSTGRES_USER="it_roadmap"
POSTGRES_PASSWORD="change-me-to-a-long-random-string"
POSTGRES_DB="it_roadmap"

# Web container connects to the db service via the docker network.
# Hostname `db` matches the compose service name.
DATABASE_URL="postgresql://it_roadmap:change-me-to-a-long-random-string@db:5432/it_roadmap?schema=public"

IP_HASH_SALT="change-me-to-a-long-random-string"
NODE_ENV="development"

# Admin auth — generate both with:  node scripts/hash-admin-password.mjs
# Required for the `admin` container (SITE_MODE=admin) only.
ADMIN_PASSWORD_HASH=""
SESSION_SECRET=""

# Cloudflare Zero Trust tunnel token (optional — only needed if you run the
# `cloudflared` service in docker-compose.yml). Get it from the Cloudflare
# dashboard: Zero Trust → Networks → Tunnels → your tunnel → connector token.
CLOUDFLARE_TUNNEL_TOKEN=""
